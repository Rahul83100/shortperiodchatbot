<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/chatbot/db" VERSION="20260225" COMMENT="XMLDB file for Moodle local/chatbot"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_chatbot_sync" COMMENT="Tracks which files have been synced to the vector database">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Sequence ID"/>
        <FIELD NAME="filehash" TYPE="char" LENGTH="40" NOTNULL="true" COMMENT="Content hash of the file"/>
        <FIELD NAME="pathnamehash" TYPE="char" LENGTH="40" NOTNULL="true" COMMENT="Pathname hash of the file instance"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="ID of the course this file belongs to"/>
        <FIELD NAME="syncstatus" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="0 = pending, 1 = synced, 2 = failed"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Timestamp when this record was last updated"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="filehash_idx" UNIQUE="false" FIELDS="filehash"/>
        <INDEX NAME="pathnamehash_idx" UNIQUE="true" FIELDS="pathnamehash"/>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
